{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ATP Knowledge Studio",
  "version": "0.1.0",
  "identifier": "studio.atp.knowledge",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ATP Knowledge Studio",
        "width": 1536,
        "height": 1024,
        "minWidth": 1200,
        "minHeight": 780,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
